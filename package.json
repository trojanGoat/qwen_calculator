{
  "name": "electron-calculator",
  "version": "1.0.0",
  "description": "A standalone Electron calculator app with dark theme, supporting basic arithmetic and advanced modes (scientific functions, history, graph).",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"electron .\" \"vite\"",
    "build": "vite build && electron-builder",
    "start": "vite"
  },
  "dependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.2.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0"

  },
  "build": {
    "appId": "com.example.electroncalculator",
    "productName": "Electron Calculator",
    "directories": {
      "app": "src"
    },
    "files": [
      "public/**/*",
      "src/**/*",
      "index.html"
    ],
    "mac": {
      "category": "PublicUtility"
    },
    "linux": {
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    }
  }
}